{
  "name": "tabtab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "description": "Chrome extension for tab management",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:release": "tsc && vite build",
    "build:debug": "tsc && vite build --mode debug",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "lint:fix": "eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json,html,css}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,json,html,css}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
